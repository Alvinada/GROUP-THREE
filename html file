<section id="home" class="hero">
        <div class="hero-content">
            <h1>Protect. Empower. Support.</h1>
            <p>Advocating for the rights of teen parents to build a better, equal future.</p>
            <div class="hero-btns">
                <a href="#about" class="btn-primary">Learn More</a>
                <a href="#services" class="btn-secondary">Get Support</a>
            </div>
        </div>
    </section>
<section id="about" class="container">
        <div class="section-title">
            <h2>Our Mission & Vision</h2>
            <hr>
        </div>
        <div class="grid">
            <div class="card">
                <h3>Our Mission</h3>
                <p>To protect and support teen parents below 18 through human rights advocacy, education, counseling, and community support programs.</p>
            </div>
            <div class="card">
                <h3>Our Vision</h3>
                <p>A society where every young parent is empowered, protected, and given equal opportunities to build a brighter future.</p>
            </div>
        </div>
    </section>
 <section id="services" class="bg-light">
        <div class="container">
            <div class="section-title">
                <h2>Why We Exist</h2>
                <p>Addressing the critical challenges faced by teen parents.</p>
            </div>
            <ul class="problem-list">
                <li><strong>Rights Education:</strong> Breaking the cycle of stigma and discrimination.</li>
                <li><strong>Safe Reporting:</strong> Providing a confidential platform for domestic violence issues.</li>
                <li><strong>Financial & Health:</strong> Bridging the gap in counseling and healthcare access.</li>
                <li><strong>Community:</strong> Connecting social workers and legal aid to those in need.</li>
            </ul>
        </div>
    </section>
 <section id="donations" class="container">
        <div class="donation-box">
            <h2>Make an Impact</h2>
            <p>Your contribution helps us provide legal aid, education, and counseling to young mothers and fathers (ages 14 to 25).</p>
            <div class="donation-options">
                <button class="amt-btn">$10</button>
                <button class="amt-btn">$25</button>
                <button class="amt-btn">$50</button>
                <input type="number" placeholder="Custom Amount">
            </div>
            <button class="btn-primary large">Proceed to Donate</button>
        </div>
    </section>

